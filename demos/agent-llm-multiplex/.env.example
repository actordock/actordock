DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
ACTORDOCK_API=http://127.0.0.1:18080
SEMANTIC_MODE=both
NUM_SANDBOXES=3
MIN_WORKERS=2
SEMANTIC_DEADLINE_SEC=600
# L3: local HF weights from llm-semantic-router (not full Semantic Router)
SEMANTIC_HF_DOMAIN=llm-semantic-router/mmbert32k-intent-classifier-merged
SEMANTIC_HF_EMBED=llm-semantic-router/mmbert-embed-32k-2d-matryoshka
# Leave DEMO_TASK unset to use built-in easy/medium/hard prompts (L3 differentiation).
# DEMO_TASK=...
# User-defined sandbox runner (stock rootfs = busybox). Must include {file}.
RUN_CODE_EXT=sh
RUN_CODE_EXEC=/bin/busybox sh {file}
# Example if you supply your own rootfs with Python:
# RUN_CODE_EXT=py
# RUN_CODE_EXEC=/usr/bin/python3 {file}
