apiVersion: ate.dev/v1alpha1
kind: ActorTemplate
metadata:
  name: base
  namespace: actordock
spec:
  workerSelector:
    matchLabels:
      workload: actordock
  pauseImage: "registry.k8s.io/pause:3.10.2@sha256:f548e0e8e3dc1896ca956272154dde3314e8cc4fde0a57577ee9fa1c63f5baf4"
  containers:
    - name: envd
      image: ko://github.com/actordock/actordock/cmd/envd
      command: ["/ko-app/envd"]
  snapshotsConfig:
    location: gs://${BUCKET_NAME}/actordock/
